import "module:std" as std

class ArtistEndpoint {
  construct() {}

  fun getArtist(id) {
    return std.Future.resolve({
      "id": id,
      "name": "Artist " + id,
      "artwork": "https://i.ytimg.com/vi/dQw4w9WgXcQ/mqdefault.jpg"
    }.toJson())
  }

  fun tracks(id, {offset, limit}) {
    return std.Future.resolve({"items": [], "total": 0}.toJson())
  }
}

export { ArtistEndpoint }
