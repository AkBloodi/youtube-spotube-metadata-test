import "module:std" as std

var Future = std.Future

class AlbumEndpoint {
  construct() {}

  fun getAlbum(id) {
    return Future.resolve({"items": [], "total": 0})
  }

  fun tracks(id, {offset, limit}) {
    return Future.resolve({"items": [], "total": 0})
  }

  fun save(id) {
    return Future.resolve({"status": "success"})
  }
}

export { AlbumEndpoint }
